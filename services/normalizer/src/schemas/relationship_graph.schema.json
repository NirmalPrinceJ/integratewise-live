{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Relationship Graph (SSOT)",
    "type": "object",
    "required": [
        "id",
        "account_id",
        "tenant_id",
        "person_name"
    ],
    "properties": {
        "id": {
            "type": "string",
            "format": "uuid"
        },
        "account_id": {
            "type": "string",
            "format": "uuid"
        },
        "tenant_id": {
            "type": "string",
            "format": "uuid"
        },
        "person_name": {
            "type": "string"
        },
        "person_email": {
            "type": "string",
            "format": "email"
        },
        "role_persona": {
            "type": "string"
        },
        "influence_level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
        },
        "sentiment_score": {
            "type": "number",
            "minimum": -1,
            "maximum": 1
        },
        "power_sponsor_strength": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
        }
    },
    "additionalProperties": true
}