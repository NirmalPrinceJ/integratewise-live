{
  "name": "@integratewise/analytics",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform analytics for IntegrateWise OS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./providers/*": {
      "import": "./dist/providers/*.mjs",
      "require": "./dist/providers/*.js",
      "types": "./dist/providers/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@amplitude/analytics-browser": "*",
    "mixpanel-browser": "*",
    "posthog-js": "*"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@amplitude/analytics-browser": {
      "optional": true
    },
    "mixpanel-browser": {
      "optional": true
    },
    "posthog-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@amplitude/analytics-browser": "^2.0.0",
    "@types/react": "^18.2.0",
    "mixpanel-browser": "^2.0.0",
    "posthog-js": "^1.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
