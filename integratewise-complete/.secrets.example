# IntegrateWise OS - Secrets Configuration
# Copy this file to .secrets and fill in your values
# DO NOT commit .secrets to version control!

# ====================
# DATABASE (Required)
# ====================
# Neon Postgres connection string (or Supabase direct connection)
NEON_CONNECTION_STRING="postgresql://user:password@host:5432/neondb?sslmode=require"

# Supabase configuration
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"

# ====================
# AI PROVIDERS
# ====================
# OpenRouter (RECOMMENDED) - Single API key for all AI models
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Legacy direct API access (only needed if not using OpenRouter)
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."

# ====================
# OBJECT STORAGE (R2)
# ====================
R2_BUCKET="integratewise-store"
R2_ACCESS_KEY=""
R2_SECRET_KEY=""

# ====================
# SECURITY
# ====================
WEBHOOK_SECRET="generate-a-strong-secret"
ADMIN_SECRET="generate-another-strong-secret"
JWT_SECRET="generate-jwt-secret"

# ====================
# OPTIONAL
# ====================
# SLACK_BOT_TOKEN=""
# HUBSPOT_API_KEY=""
