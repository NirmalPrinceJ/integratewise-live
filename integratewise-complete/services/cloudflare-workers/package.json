{
  "name": "cloudflare-workers",
  "version": "1.0.0",
  "description": "Adaptive Spine Cloudflare Workers - Loader and Connector Manager",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:loader": "wrangler dev --config wrangler.loader.toml",
    "dev:connector": "wrangler dev --config wrangler.connector.toml",
    "deploy:loader": "wrangler deploy --config wrangler.loader.toml",
    "deploy:connector": "wrangler deploy --config wrangler.connector.toml",
    "deploy": "pnpm deploy:loader && pnpm deploy:connector"
  },
  "dependencies": {
    "hono": "^4.6.15",
    "@neondatabase/serverless": "^0.10.3",
    "papaparse": "^5.4.1",
    "pdfjs-dist": "^4.9.155"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250117.0",
    "@types/papaparse": "^5.3.15",
    "wrangler": "^4.53.0"
  }
}
