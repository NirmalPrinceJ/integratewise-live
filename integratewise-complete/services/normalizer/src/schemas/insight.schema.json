{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Generated Insight (SSOT)",
    "type": "object",
    "required": [
        "insight_id",
        "account_id",
        "insight_text",
        "tenant_id"
    ],
    "properties": {
        "insight_id": {
            "type": "string",
            "format": "uuid"
        },
        "account_id": {
            "type": "string",
            "format": "uuid"
        },
        "tenant_id": {
            "type": "string",
            "format": "uuid"
        },
        "insight_text": {
            "type": "string"
        },
        "recommended_action": {
            "type": "string"
        },
        "status": {
            "type": "string",
            "enum": [
                "new",
                "reviewed",
                "dismissed",
                "escalated"
            ]
        },
        "product_id": {
            "type": "string"
        },
        "stream_id": {
            "type": "string"
        }
    },
    "additionalProperties": true
}